# Backend Environment Variables
# Copie ce fichier vers .env pour le développement local.
# En production, définis ces variables dans Render Dashboard > Settings > Environment Variables.

# Application
NODE_ENV=production
PORT=10000

# URL du frontend Vercel. Accepte aussi CLIENT_URL.
CLIENT_URL=https://TON_APP.vercel.app

# JWT Secret
JWT_SECRET=ton_secret_jwt_tres_long_et_aleatoire
JWT_EXPIRES_IN=7d

# MySQL Aiven
# Tu peux utiliser MYSQL_URL ou DATABASE_URL.
MYSQL_URL=mysql://avnadmin:mot_de_passe@mysql-project.a.aivencloud.com:12345/defaultdb
DB_SSL=true
DB_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Alternative locale sans MYSQL_URL :
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=senegram
# DB_SSL=false

# VAPID Keys pour Web Push Notifications
# Génère avec: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=ta_cle_publique_vapid
VAPID_PRIVATE_KEY=ta_cle_privee_vapid
VAPID_SUBJECT=mailto:admin@example.com

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=52428800
# En production Render, laisse false/vide: les uploads locaux sont ephemeres.
ALLOW_LOCAL_UPLOADS=false

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# WebRTC TURN optionnel
TURN_URL=
TURN_USERNAME=
TURN_PASSWORD=

# S3-compatible storage (Backblaze B2, Cloudflare R2, AWS S3, Supabase, etc.)
# Backblaze B2 example:
# S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# S3_REGION=us-west-004
# S3_ACCESS_KEY_ID=ton_access_key
# S3_SECRET_ACCESS_KEY=ton_secret_key
# S3_BUCKET=senegram-uploads
# S3_PUBLIC_URL=https://s3.us-west-004.backblazeb2.com/senegram-uploads
# Pour Backblaze, un bucket avec majuscules peut etre refuse par l'API S3.
# Le backend tentera alors automatiquement l'API native B2.
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_URL=

# Alias acceptes si tu preferes nommer les variables Backblaze:
# B2_ENDPOINT=
# B2_REGION=
# B2_KEY_ID=
# B2_APPLICATION_KEY=
# B2_BUCKET=
# B2_PUBLIC_URL=

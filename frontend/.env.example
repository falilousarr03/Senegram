# Frontend Environment Variables
# Copie ce fichier vers .env.local pour le développement
# Pour la production, définis ces variables dans Vercel Dashboard > Settings > Environment Variables

# URL du backend Render, sans /api à la fin.
VITE_API_URL=https://senegram-backend.onrender.com
VITE_SOCKET_URL=https://senegram-backend.onrender.com

# VAPID Public Key pour Web Push (must match Render backend)
# Optionnel : si absent, le frontend récupère /api/push/public-key depuis le backend.
VITE_VAPID_PUBLIC_KEY=ta_cle_publique_vapid

# Optionnel: Serveur TURN pour WebRTC (recommandé pour la production)
# VITE_TURN_URL=turn:votre-serveur-turn.com:3478?transport=udp
# VITE_TURN_USERNAME=votre-username
# VITE_TURN_PASSWORD=votre-password
